# Copy to .env (gitignored) and adjust as needed.
# All services read these via docker compose; the API also reads them when run directly via `make api-run`.

# --- Postgres ---
POSTGRES_USER=evernest
POSTGRES_PASSWORD=evernest_dev
POSTGRES_DB=evernest
POSTGRES_PORT=5432

# --- API ---
API_PORT=8080
API_BIND=0.0.0.0
# When the API runs inside docker compose, DATABASE_URL points at the db service.
# When the API runs natively (make api-run), use the host-side override below.
DATABASE_URL=postgres://evernest:evernest_dev@db:5432/evernest?sslmode=disable
DATABASE_URL_LOCAL=postgres://evernest:evernest_dev@localhost:5432/evernest?sslmode=disable

# Hex-encoded 32-byte key used to sign access tokens (HS256). Generate one with:
#   openssl rand -hex 32
JWT_SECRET=change-me-development-only-do-not-use-in-production-please-replace

# Access token lifetime (Go duration) and refresh token lifetime (days)
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# Origin allowed by CORS (web dev server)
CORS_ALLOW_ORIGIN=http://localhost:5173

# Public base URL used to construct invite links
PUBLIC_WEB_ORIGIN=http://localhost:5173

# --- Web ---
WEB_PORT=5173
VITE_API_BASE_URL=http://localhost:8080
