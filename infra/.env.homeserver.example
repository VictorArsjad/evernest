# Minimal .env for infra/docker-compose.homeserver.yml
# Copy to the repo root as .env (or pass with --env-file).

# --- Postgres (change the password!) ---
POSTGRES_USER=evernest
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=evernest

# --- API secrets ---
# openssl rand -hex 32
JWT_SECRET=replace-with-output-of-openssl-rand-hex-32

# GHCR image. Pin a commit tag for reproducible deploys, or use :latest after CI.
EVERNEST_API_IMAGE=ghcr.io/victorarsjad/evernest-api:743149a

# Web app origin (GitHub Pages example). No trailing slash.
CORS_ALLOW_ORIGIN=https://victorarsjad.github.io
PUBLIC_WEB_ORIGIN=https://victorarsjad.github.io

# Cross-origin prod (FE on github.io, API on tailscale) needs SameSite=none.
COOKIE_SAMESITE=none

# --- Tailscale (one-time bootstrap; state persists in the ts-state volume) ---
TS_AUTHKEY=tskey-auth-...
TS_HOSTNAME=evernest
