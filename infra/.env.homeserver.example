# Minimal .env for infra/docker-compose.homeserver.yml
# Copy to the repo root as .env (or pass with --env-file).

# --- Postgres (change the password!) ---
POSTGRES_USER=evernest
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=evernest

# --- API secrets ---
# openssl rand -hex 32
JWT_SECRET=replace-with-output-of-openssl-rand-hex-32

# GHCR image. Pin a commit tag for reproducible deploys, or use :latest after CI.
EVERNEST_API_IMAGE=ghcr.io/victorarsjad/evernest-api:743149a

# Web app origin. The API binary serves the SPA from this same ts.net host
# (same-origin), so point both at the tailnet URL. No trailing slash.
CORS_ALLOW_ORIGIN=https://evernest.taila60dd0.ts.net
PUBLIC_WEB_ORIGIN=https://evernest.taila60dd0.ts.net

# Same-origin (FE + API on one ts.net host) lets the refresh cookie be
# first-party, so SameSite=lax (which iOS WebKit does not evict). Use "none"
# only if you ever split the FE back onto a different origin.
COOKIE_SAMESITE=lax

# --- Tailscale (one-time bootstrap; state persists in the ts-state volume) ---
TS_AUTHKEY=tskey-auth-...
TS_HOSTNAME=evernest
